# Copy this file to .env and update with your SQL database credentials.
# PostgreSQL example:
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/stress_app

# Comma-separated list of allowed CORS origins.
# Defaults include local dev and GitHub Pages origins for Mystic-a when not set.
# Example for a custom backend domain:
# ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,https://Mystic-a.github.io,https://Mystic-a.github.io/stress_prediction
